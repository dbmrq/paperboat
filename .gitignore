# Generated by Cargo
/target/

# Cargo.lock is included for binaries, but some prefer to exclude it
# Uncomment if you want to ignore it:
# Cargo.lock

# Backup files
*.bak
*~

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs (keep directory structure via .gitkeep)
/logs/*
!/logs/.gitkeep
*.log

# Environment files (may contain secrets)
.env
.env.*
*.env

# Credentials and secrets
*.pem
*.key
*.cert
*.crt
secrets/
credentials/

# Build artifacts
*.so
*.dylib
*.dll

# Windows
Thumbs.db

# Coverage reports
*.lcov
*.profraw
*.profdata
coverage/
tarpaulin-report.html

# Test output
test-output/
